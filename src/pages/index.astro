---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured);
---

<BaseLayout title="Home" description="Alex The App Guy — Mobile Developer. When You Need A Developer Who Delivers.">

  <!-- Hero -->
  <section id="hero-section" class="relative overflow-hidden bg-zinc-950 py-20">

    <!-- Atmosphere: radial bloom centered on avatar -->
    <div id="bloom-main" class="pointer-events-none absolute h-[700px] w-[700px] rounded-full bg-sky-500/[0.09] blur-[110px]" style="top:0;left:50%;transform:translate(-50%,-33%)"></div>
    <!-- Secondary warm bloom -->
    <div id="bloom-secondary" class="pointer-events-none absolute h-[400px] w-[400px] rounded-full bg-indigo-500/[0.06] blur-[90px]" style="top:50%;left:33%;transform:translate(-50%,-50%)"></div>

    <div class="relative z-10 mx-auto flex max-w-5xl flex-col items-center px-6 text-center">

      <!-- Avatar — Apple Intelligence glow -->
      <div class="animate-fade-scale relative mb-8 h-64 w-64">

        <!-- Outer aura: blurred, large, behind everything -->
        <div class="animate-ai-spin pointer-events-none absolute -inset-6 rounded-full opacity-50 blur-2xl"
             style="background:conic-gradient(from 0deg,#60a5fa,#a78bfa,#e879f9,#fb7185,#fb923c,#60a5fa)">
        </div>

        <!-- Sharp border ring: rotates, reveals edge via inset solid div -->
        <div class="animate-ai-spin absolute inset-0 rounded-full"
             style="background:conic-gradient(from 0deg,#60a5fa,#a78bfa,#e879f9,#fb7185,#fb923c,#60a5fa);padding:2.5px">
          <div class="h-full w-full rounded-full bg-zinc-950"></div>
        </div>

        <!-- Image clipped inside the border -->
        <div class="absolute inset-[2.5px] z-10 overflow-hidden rounded-full">
          <img
            src="/headshot.png"
            alt="Alex The App Guy"
            class="h-full w-full object-cover object-top"
          />
        </div>
      </div>

      <!-- Name — gradient text, fades up after avatar -->
      <h1 class="animate-fade-up mb-3 bg-gradient-to-b from-white via-white to-zinc-400
                 bg-clip-text text-5xl font-bold tracking-tight text-transparent
                 [animation-delay:200ms]">
        Alex The App Guy
      </h1>

      <!-- Tagline -->
      <p class="animate-fade-up mb-10 max-w-xl text-xl leading-relaxed text-zinc-400
                [animation-delay:350ms]">
        When You Need A Developer Who Delivers.
      </p>

      <!-- CTAs -->
      <div class="animate-fade-up flex flex-wrap items-center justify-center gap-4
                  [animation-delay:500ms]">
        <a
          href="#featured-work"
          class="rounded-full bg-sky-500 px-7 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-sky-600"
        >
          View My Work
        </a>
        <a
          href="/contact"
          class="rounded-full border border-zinc-700 bg-white/5 px-7 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:border-zinc-500 hover:bg-white/10"
        >
          Get In Touch
        </a>
      </div>

    </div>
  </section>

  <!-- Skills strip -->
  <section class="border-y border-zinc-100 bg-zinc-50 py-8">
    <div class="mx-auto max-w-5xl px-6">
      <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        {["TypeScript", "React Native", "Swift", "Kotlin"].map((skill) => (
          <li class="text-sm font-medium text-zinc-500">{skill}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Featured Projects -->
  <section id="featured-work" class="mx-auto max-w-5xl px-6 py-20">
    <div class="mb-10">
      <h2 class="text-2xl font-bold tracking-tight text-zinc-900">Featured Work</h2>
      <p class="mt-1 text-sm text-zinc-500">A selection of recent mobile projects.</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>

  <!-- CTA banner -->
  <section class="bg-zinc-900 py-20">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="mb-3 text-3xl font-bold tracking-tight text-white">
        Ready to build something great?
      </h2>
      <p class="mb-8 text-zinc-400">
        I take on select freelance and contract work. Let's talk about your project.
      </p>
      <a
        href="/contact"
        class="rounded-full bg-sky-500 px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-sky-600"
      >
        Start a Conversation
      </a>
    </div>
  </section>

<script>
  const hero      = document.querySelector<HTMLElement>("#hero-section")!;
  const bloomMain = document.querySelector<HTMLElement>("#bloom-main")!;
  const bloomSec  = document.querySelector<HTMLElement>("#bloom-secondary")!;

  // Normalized mouse position (0–1) relative to hero
  let mx = 0.5, my = 0.5;

  // Two independent lerp targets — main tracks cursor, secondary lags behind
  let mainX = 0, mainY = 0;
  let secX  = 0, secY  = 0;

  hero.addEventListener("mousemove", (e: MouseEvent) => {
    const r = hero.getBoundingClientRect();
    mx = (e.clientX - r.left) / r.width;
    my = (e.clientY - r.top)  / r.height;
  });

  // Reset gently on leave
  hero.addEventListener("mouseleave", () => { mx = 0.5; my = 0.5; });

  (function tick() {
    requestAnimationFrame(tick);

    // Main bloom: fast, ±160px travel from rest
    mainX += ((mx - 0.5) * 320 - mainX) * 0.06;
    mainY += ((my - 0.5) * 200 - mainY) * 0.06;
    bloomMain.style.transform =
      `translate(calc(-50% + ${mainX}px), calc(-33% + ${mainY}px))`;

    // Secondary bloom: slower + smaller travel, feels like a shadow
    secX += ((mx - 0.5) * 160 - secX) * 0.035;
    secY += ((my - 0.5) * 120 - secY) * 0.035;
    bloomSec.style.transform =
      `translate(calc(-50% + ${secX}px), calc(-50% + ${secY}px))`;
  })();
</script>

</BaseLayout>
