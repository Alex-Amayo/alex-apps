---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectShowcase from "../components/ProjectShowcase.astro";
import ShortsCarousel from "../components/ShortsCarousel.astro";
import { projects } from "../data/projects";
import { shorts } from "../data/shorts";


---

<BaseLayout title="Home" description="Alex Amayo — Mobile Developer. When You Need A Developer Who Delivers.">

  <!-- Tiled layout: each section is a full-bleed #F5F5F6 band separated by
       white gutters (gap-gutter); content is capped to max-w-6xl inside so it
       never hugs the viewport edge — Apple homepage style. -->
  <div class="flex flex-col gap-gutter">

    <!-- Hero — light tile -->
    <section class="bg-[#F5F5F6] py-24">
      <div class="mx-auto flex max-w-6xl flex-col items-center px-gutter text-center">

        <!-- Avatar — app icon (squircle) with Apple Intelligence glow -->
        <div class="animate-fade-scale relative mb-8 h-48 w-48">

          <!-- Outer aura: blurred, large, behind everything -->
          <div class="pointer-events-none absolute -inset-1 rounded-[22%] opacity-50 blur-md"
               style="background:conic-gradient(from 0deg,#60a5fa,#a78bfa,#e879f9,#fb7185,#fb923c,#60a5fa)">
          </div>

          <!-- Sharp border ring: static gradient, reveals edge via inset solid div -->
          <div class="absolute inset-0 rounded-[22%]"
               style="background:conic-gradient(from 0deg,#60a5fa,#a78bfa,#e879f9,#fb7185,#fb923c,#60a5fa);padding:2.5px">
            <div class="h-full w-full rounded-[22%] bg-[#F5F5F6]"></div>
          </div>

          <!-- Image clipped inside the border -->
          <div class="absolute inset-[2.5px] z-10 overflow-hidden rounded-[22%]">
            <img
              src="/headshot.png"
              alt="Alex Amayo"
              class="h-full w-full object-cover object-top"
            />
          </div>
        </div>

        <!-- Name — fades up after avatar -->
        <h1 class="animate-fade-up mb-3 text-6xl font-semibold tracking-tight text-zinc-900 sm:text-7xl
                   [animation-delay:200ms]">
          Alex Amayo
        </h1>

        <!-- Tagline -->
        <p class="animate-fade-up mb-5 max-w-2xl text-xl leading-relaxed text-zinc-500 sm:text-2xl
                  [animation-delay:350ms]">
          When You Need A Developer Who Delivers.
        </p>

        <!-- Skills line -->
        <p class="animate-fade-up mb-10 text-sm font-medium text-zinc-400
                  [animation-delay:425ms]">
          {["TypeScript", "React Native", "Swift", "Kotlin"].join("  ·  ")}
        </p>

        <!-- CTAs -->
        <div class="animate-fade-up flex flex-wrap items-center justify-center gap-4
                    [animation-delay:500ms]">
          <a
            href="#featured-work"
            class="rounded-full bg-sky-500 px-7 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-sky-600"
          >
            View My Work
          </a>
          <a
            href="/contact"
            class="rounded-full border border-zinc-300 bg-white px-7 py-3 text-sm font-semibold text-zinc-900 transition-colors hover:bg-zinc-50"
          >
            Get In Touch
          </a>
        </div>

      </div>
    </section>

    <!-- Watch — white band -->
    <section id="watch" class="scroll-mt-16 bg-[#F5F5F6] py-20">
      <div class="mx-auto max-w-6xl px-gutter">
        <div class="mb-10">
          <h2 class="text-4xl font-semibold tracking-tight text-zinc-900 sm:text-5xl">Watch.</h2>
          <p class="mt-3 text-lg text-zinc-500 sm:text-xl">Quick clips on mobile dev and building apps.</p>
        </div>
        <ShortsCarousel shorts={shorts} />
      </div>
    </section>

    <!-- Projects — Apple tile grid: no header, no rounding, white gutters all round -->
    <section id="featured-work" class="scroll-mt-16">
      <div class="grid grid-cols-1 gap-gutter px-gutter sm:grid-cols-2">
        {projects.map((project) => (
          <ProjectShowcase {...project} />
        ))}
      </div>
    </section>

    <!-- CTA banner — light tile -->
    <section class="bg-[#F5F5F6] py-24">
      <div class="mx-auto max-w-2xl px-gutter text-center">
        <h2 class="mb-3 text-4xl font-semibold tracking-tight text-zinc-900 sm:text-5xl">
          Get in touch.
        </h2>
        <p class="mb-8 text-lg text-zinc-500 sm:text-xl">
          Open to impactful engineering roles.
        </p>
        <a
          href="/contact"
          class="rounded-full bg-sky-500 px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-sky-600"
        >
          Get In Touch
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
