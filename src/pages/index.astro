---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCarousel from "../components/ProjectCarousel.astro";
import ShortsCarousel from "../components/ShortsCarousel.astro";
import { projects } from "../data/projects";
import { shorts } from "../data/shorts";

const myApps = projects.filter((p) => p.owned);
const workedOn = projects.filter((p) => !p.owned);
---

<BaseLayout title="Home" description="Alex J Amayo — I build apps for iOS, Android and the web with React Native.">

  <!-- Tiled layout: each section is a full-bleed #F5F5F6 band separated by
       white gutters (gap-gutter); content is capped to max-w-6xl inside so it
       never hugs the viewport edge — Apple homepage style. -->
  <div class="flex flex-col gap-gutter">

    <!-- Hero — light tile -->
    <section class="bg-[#F5F5F6] py-24">
      <div class="mx-auto flex max-w-6xl flex-col items-center px-gutter text-center">

        <!-- Avatar — app icon (squircle) with a single static gradient ring -->
        <div
          class="animate-fade-scale mb-8 h-48 w-48 rounded-[22%] p-[2.5px]"
          style="background:linear-gradient(135deg,#60a5fa,#a78bfa,#e879f9,#fb7185,#fb923c)"
        >
          <img
            src="/headshot.png"
            alt="Alex Amayo"
            class="h-full w-full rounded-[21%] object-cover object-top"
          />
        </div>

        <!-- Name — fades up after avatar -->
        <h1 class="animate-fade-up mb-3 text-6xl font-semibold tracking-tight text-zinc-900 sm:text-7xl
                   [animation-delay:200ms]">
          Hi, I'm Alex
        </h1>

        <!-- Tagline -->
        <p class="animate-fade-up mb-10 max-w-2xl text-xl leading-relaxed text-zinc-500 sm:text-2xl
                  [animation-delay:350ms]">
          I build apps for iOS, Android and the web with React Native.
        </p>

        <!-- CTAs -->
        <div class="animate-fade-up flex flex-wrap items-center justify-center gap-4
                    [animation-delay:500ms]">
          <a
            href="/contact"
            class="rounded-full bg-sky-500 px-7 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-sky-600"
          >
            Get In Touch
          </a>
        </div>

      </div>
    </section>

    <!-- Projects — Mac-page pattern: centered header + rounded tiles on one continuous band -->
    <section class="bg-[#F5F5F6] py-14">
      {myApps.length > 0 && (
        <>
          <div class="mx-auto mb-10 max-w-6xl px-gutter">
            <h2 class="text-4xl font-semibold tracking-tight text-zinc-900 sm:text-5xl">
              My Apps
            </h2>
          </div>
          <ProjectCarousel projects={myApps} />
        </>
      )}

      {workedOn.length > 0 && (
        <>
          <div class="mx-auto mb-10 mt-16 max-w-6xl px-gutter">
            <h2 class="text-4xl font-semibold tracking-tight text-zinc-900 sm:text-5xl">
              Apps I've worked on
            </h2>
          </div>
          <ProjectCarousel projects={workedOn} />
        </>
      )}
    </section>

    <!-- Videos — gated behind the `videos-section` PostHog feature flag.
         Hidden by default; revealed only when the flag is enabled. -->
    <section id="videos-section" class="hidden bg-[#F5F5F6] py-20">
      <div class="mx-auto max-w-6xl px-gutter">
        <div class="mb-10">
          <h2 class="text-4xl font-semibold tracking-tight text-zinc-900 sm:text-5xl">Videos</h2>
        </div>
        <ShortsCarousel shorts={shorts} />
      </div>
    </section>

    <script is:inline>
      window.posthog?.onFeatureFlags(function () {
        if (window.posthog.isFeatureEnabled("videos-section")) {
          document.getElementById("videos-section")?.classList.remove("hidden");
        }
      });
    </script>

    <!-- CTA banner — light tile -->
    <section class="bg-[#F5F5F6] py-24">
      <div class="mx-auto max-w-2xl px-gutter text-center">
        <h2 class="mb-8 text-4xl font-semibold tracking-tight text-zinc-900 sm:text-5xl">
          Get in touch.
        </h2>
        <a
          href="/contact"
          class="rounded-full bg-sky-500 px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-sky-600"
        >
          Get In Touch
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
