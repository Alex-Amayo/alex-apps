---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog" description="Thoughts on mobile development, Swift, and building great apps.">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-12">
      <h1 class="mb-3 text-4xl font-bold tracking-tight text-zinc-900">Blog</h1>
      <p class="text-lg text-zinc-500">
        Thoughts on mobile development, Swift, React Native, and shipping software.
      </p>
    </header>

    <div class="flex flex-col gap-5">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
        />
      ))}
    </div>
  </div>
</BaseLayout>
