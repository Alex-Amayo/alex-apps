---
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 bg-zinc-50">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-8">
    <p class="text-xs text-zinc-500">© {year} alexamayo.com. All rights reserved.</p>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-zinc-500 hover:text-zinc-900 transition-colors"
        aria-label="GitHub"
      >
        GitHub
      </a>
      <a
        href="https://linkedin.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-zinc-500 hover:text-zinc-900 transition-colors"
        aria-label="LinkedIn"
      >
        LinkedIn
      </a>
    </div>
  </div>
</footer>
