---
import ScreenshotGallery from "./ScreenshotGallery.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  screenshots?: string[];
  tags: string[];
  appStore?: string;
  playStore?: string;
  web?: string;
  github?: string;
}

const { title, description, image, screenshots, tags, appStore, playStore, web, github } =
  Astro.props;

const hasLinks = appStore || playStore || web || github;
---

<article class="rounded-[28px] bg-white p-6 sm:p-8">
  <h3 class="text-xl font-semibold text-zinc-900">{title}</h3>
  <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-500">{description}</p>

  <div class="mt-4 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-medium text-zinc-600">
        {tag}
      </span>
    ))}
  </div>

  {hasLinks && (
    <div class="mt-4 flex flex-wrap gap-2">
      {appStore && (
        <a
          href={appStore}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700 transition-colors hover:border-zinc-300 hover:bg-zinc-50"
        >
          <img src="https://svgl.app/library/appstore.svg" alt="" class="h-4 w-4" loading="lazy" />
          App Store
        </a>
      )}
      {playStore && (
        <a
          href={playStore}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700 transition-colors hover:border-zinc-300 hover:bg-zinc-50"
        >
          <img src="https://svgl.app/library/googleplay.svg" alt="" class="h-4 w-4" loading="lazy" />
          Google Play
        </a>
      )}
      {web && (
        <a
          href={web}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700 transition-colors hover:border-zinc-300 hover:bg-zinc-50"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          Web
        </a>
      )}
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700 transition-colors hover:border-zinc-300 hover:bg-zinc-50"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      )}
    </div>
  )}

  {screenshots?.length ? (
    <ScreenshotGallery screenshots={screenshots} title={title} class="mt-6" />
  ) : image ? (
    <div class="mt-6 overflow-hidden rounded-xl border border-zinc-100">
      <img src={image} alt={title} class="h-48 w-full object-cover" loading="lazy" />
    </div>
  ) : (
    <div class="mt-6 flex h-48 items-center justify-center rounded-xl border border-zinc-100 bg-zinc-100">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
    </div>
  )}
</article>
